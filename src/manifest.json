{
  "manifest_version": 3,
  "name": "ApplySharp",
  "version": "1.0.0",
  "description": "Local-first AI Job Assistant - Smart job matching, cover letters, and autofill",

  "permissions": [
    "storage",
    "unlimitedStorage",
    "activeTab",
    "contextMenus",
    "alarms",
    "notifications"
  ],

  "host_permissions": [
    "https://www.linkedin.com/jobs/*",
    "https://www.indeed.com/*",
    "https://boards.greenhouse.io/*",
    "https://*.greenhouse.io/*",
    "https://jobs.lever.co/*",
    "https://*.lever.co/*",
    "https://*.myworkdayjobs.com/*",
    "https://www.dice.com/*",
    "https://www.monster.com/*",
    "https://www.glassdoor.com/*",
    "https://www.ziprecruiter.com/*",
    "https://wellfound.com/*",
    "https://*.ashbyhq.com/*",
    "https://*.smartrecruiters.com/*",
    "https://*.icims.com/*",
    "https://*.taleo.net/*",
    "https://*.bamboohr.com/*",
    "https://*.jazzhr.com/*",
    "https://*.jobvite.com/*",
    "https://*.breezy.hr/*",
    "https://*.rippling.com/*",
    "https://*.recruitee.com/*",
    "https://*.workable.com/*",
    "http://localhost:*/*"
  ],

  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://www.indeed.com/*",
        "https://www.dice.com/*",
        "https://www.monster.com/*",
        "https://www.ziprecruiter.com/*",
        "https://www.glassdoor.com/*",
        "https://wellfound.com/*",
        "https://boards.greenhouse.io/*",
        "https://*.greenhouse.io/*",
        "https://jobs.lever.co/*",
        "https://*.lever.co/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.ashbyhq.com/*",
        "https://*.smartrecruiters.com/*",
        "https://*.icims.com/*",
        "https://*.taleo.net/*",
        "https://*.bamboohr.com/*",
        "https://*.applytojob.com/*",
        "https://*.jobvite.com/*",
        "https://*.breezy.hr/*",
        "https://*.rippling.com/*",
        "https://*.recruitee.com/*",
        "https://*.workable.com/*"
      ],
      "js": ["src/content/index.ts"],
      "css": ["src/content/styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://www.indeed.com/*",
        "https://www.dice.com/*",
        "https://www.monster.com/*",
        "https://www.ziprecruiter.com/*",
        "https://www.glassdoor.com/*",
        "https://wellfound.com/*",
        "https://boards.greenhouse.io/*",
        "https://*.greenhouse.io/*",
        "https://jobs.lever.co/*",
        "https://*.lever.co/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.ashbyhq.com/*",
        "https://*.smartrecruiters.com/*",
        "https://*.icims.com/*",
        "https://*.taleo.net/*",
        "https://*.bamboohr.com/*",
        "https://*.applytojob.com/*",
        "https://*.jobvite.com/*",
        "https://*.breezy.hr/*",
        "https://*.rippling.com/*",
        "https://*.recruitee.com/*",
        "https://*.workable.com/*"
      ],
      "js": ["src/content/autofill-content.ts"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],

  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "ApplySharp"
  },

  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },

  "web_accessible_resources": [
    {
      "resources": ["src/content/styles.css"],
      "matches": [
        "https://www.linkedin.com/*",
        "https://www.indeed.com/*",
        "https://www.dice.com/*",
        "https://*.greenhouse.io/*",
        "https://*.lever.co/*",
        "https://*.myworkdayjobs.com/*"
      ]
    }
  ]
}
